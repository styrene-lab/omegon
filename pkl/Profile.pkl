/// Omegon profile schema.
///
/// The profile is the persistent user configuration that survives across
/// sessions. Stored as JSON at `~/.omegon/profile.json` (global) or
/// `.omegon/profile.json` (project-level).
///
/// This schema validates the structure; rpkl evaluates it at load time
/// without changing the on-disk JSON format.
module Profile

/// Model reference — provider:modelId pair.
class ModelRef {
  provider: String(length > 0)
  modelId: String(length > 0)
}

/// Stable, human-readable profile identifier for compact UI surfaces.
name: String(length > 0)?

/// Optional longer display label for settings and help surfaces.
displayName: String(length > 0)?

/// Last used model selection.
lastUsedModel: ModelRef?

/// Thinking level for reasoning-capable models.
thinkingLevel: ("off"|"minimal"|"low"|"medium"|"high")?

/// Maximum agent turns per invocation.
maxTurns: Int(this > 0)?

/// Provider preference order. First = most preferred.
providerOrder: Listing<String>?

/// Explicit fallback providers for interactive routing. Empty/missing means
/// fail explicitly when selected-provider credentials are unavailable.
fallbackProviders: Listing<String>?

/// Default behavioral posture.
defaultPosture: ("explorator"|"fabricator"|"architect"|"devastator")?

class Permissions {
  /// Directories outside the workspace the agent can access without
  /// per-operation confirmation. Paths are expanded at runtime (~ → $HOME).
  trustedDirectories: Listing<String>?
}

/// Unified operator permission policy.
permissions: Permissions?

/// Legacy compatibility alias for permissions.trustedDirectories.
trustedDirectories: Listing<String>?

/// Update channel for self-update.
updateChannel: ("stable"|"nightly")?

/// Auto-update on session exit when a newer version is available.
autoUpdate: Boolean?

/// Tool output density.
toolDetail: ("lean"|"compact"|"detailed"|"verbose")?

/// Mouse interaction mode. false = terminal-native text selection.
mouse: Boolean?

/// Active persona to restore on session start.
persona: String?

/// Active tone to restore on session start.
tone: String?
