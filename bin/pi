#!/usr/bin/env node
/**
 * Omegon pi entry point.
 *
 * Sets PI_CODING_AGENT_DIR to the omegon repo root so pi loads all agent
 * configuration (extensions, themes, skills, AGENTS.md) from omegon rather
 * than from ~/.pi/agent/. The pi core comes from vendor/pi-mono.
 *
 * PI_CODING_AGENT_DIR can be overridden at runtime for testing:
 *   PI_CODING_AGENT_DIR=/path/to/other pi ...
 */
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

const __filename = fileURLToPath(import.meta.url);
const omegonRoot = dirname(dirname(__filename));

// Only set if not already overridden
if (!process.env.PI_CODING_AGENT_DIR) {
  process.env.PI_CODING_AGENT_DIR = omegonRoot;
}

await import(join(omegonRoot, "vendor/pi-mono/packages/coding-agent/dist/cli.js"));
