---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Sidebar sections defined statically (Astro.glob deprecated)

const sections = [
  {
    title: "Getting Started",
    items: [
      { label: "Introduction", href: "/docs/" },
      { label: "Get Working Fast", href: "/docs/get-started" },
      { label: "Installation", href: "/docs/install" },
      { label: "Quick Start", href: "/docs/quickstart" },
      { label: "Tutorial", href: "/docs/tutorial" },
      { label: "Migration Guide", href: "/docs/migration" },
    ],
  },
  {
    title: "Concepts",
    items: [
      { label: "Three-Axis Model", href: "/docs/three-axis-model" },
      { label: "Providers", href: "/docs/providers" },
      { label: "Design Tree", href: "/docs/design-tree" },
      { label: "OpenSpec Lifecycle", href: "/docs/openspec" },
      { label: "Cleave & Delegate", href: "/docs/cleave" },
      { label: "Project Memory", href: "/docs/memory" },
      { label: "Sessions", href: "/docs/sessions" },
    ],
  },
  {
    title: "Interface",
    items: [
      { label: "TUI & Dashboard", href: "/docs/tui" },
      { label: "Ecosystem & Integrations", href: "/docs/ecosystem" },
      { label: "OpenAPI Tools", href: "/docs/openapi-tools" },
      { label: "Plugins & Personas", href: "/docs/plugins" },
      { label: "Extensions", href: "/docs/extensions" },
    ],
  },
  {
    title: "Reference",
    items: [
      { label: "Commands", href: "/docs/commands" },
      { label: "Skills", href: "/docs/skills" },
      { label: "FAQ", href: "/docs/faq" },
      { label: "Changelog", href: "/changelog" },
    ],
  },
  {
    title: "Development",
    items: [
      { label: "Contributing", href: "/docs/contributing" },
      { label: "Security & Supply Chain", href: "/docs/security" },
      { label: "Architecture", href: "/docs/architecture/routing" },
      { label: "Design Graph", href: "/docs/architecture/graph" },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Omegon Docs</title>
  {description && <meta name="description" content={description} />}
  {import.meta.env.PUBLIC_I2P_BUILD ? (
    <link href="/fonts/fonts.css" rel="stylesheet" />
  ) : (
    <>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Tomorrow:wght@400;600;700&display=swap" rel="stylesheet" />
    </>
  )}
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
</head>
<body>
  <nav class="topnav">
    <div class="topnav-left">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="5" x2="17" y2="5" />
          <line x1="3" y1="10" x2="17" y2="10" />
          <line x1="3" y1="15" x2="17" y2="15" />
        </svg>
      </button>
      <a href="/" class="topnav-logo">Omegon</a>
    </div>
    <div class="topnav-links">
      <a href="/docs/">Docs</a>
      <a href="/changelog">Changelog</a>
      <a href="https://github.com/styrene-lab/omegon">GitHub</a>
    </div>
  </nav>

  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
  <div class="docs-layout">
    <aside class="sidebar" id="sidebar">
      {sections.map((section) => (
        <div class="sidebar-section">
          <div class="sidebar-heading">{section.title}</div>
          <ul>
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={["sidebar-link", { active: currentPath === item.href || currentPath === item.href + "/" }]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>

    <main class="docs-content">
      <slot />
    </main>
  </div>

  <footer class="docs-footer">
    <a href="https://github.com/styrene-lab/omegon">GitHub</a> ·
    <a href="https://github.com/styrene-lab/omegon/releases">Releases</a> ·
    <a href="https://github.com/styrene-lab/omegon/blob/main/LICENSE">BSL 1.1</a> ·
    <a href="/terms">Terms</a> ·
    <a href="/privacy">Privacy</a> ·
    © 2024–2026 Black Meridian, LLC
  </footer>
</body>
</html>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border-dim);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .topnav-logo {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.5px;
  }
  .topnav-logo:hover { text-decoration: none; }
  .topnav-links {
    display: flex;
    gap: 20px;
    font-size: 14px;
  }
  .topnav-links a { color: var(--muted); }
  .topnav-links a:hover { color: var(--fg); text-decoration: none; }

  .site-banner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 24px;
    border-bottom: 1px solid var(--border-dim);
    color: var(--muted);
    font-size: 13px;
  }
  .site-banner a {
    color: var(--accent);
  }

  .docs-layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 120px);
  }

  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    border-right: 1px solid var(--border-dim);
    padding: 24px 16px;
    position: sticky;
    top: 49px;
    height: calc(100vh - 49px);
    overflow-y: auto;
  }
  .sidebar-section { margin-bottom: 20px; }
  .sidebar-heading {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--dim);
    font-weight: 600;
    margin-bottom: 6px;
    padding: 0 8px;
  }
  .sidebar ul { list-style: none; margin: 0; padding: 0; }
  .sidebar li { margin: 0; }
  .sidebar-link {
    display: block;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 14px;
    color: var(--muted);
    transition: color 0.1s, background 0.1s;
  }
  .sidebar-link:hover {
    color: var(--fg);
    background: var(--card-bg);
    text-decoration: none;
  }
  .sidebar-link.active {
    color: var(--accent);
    background: var(--card-bg);
    font-weight: 600;
  }

  .docs-content {
    flex: 1;
    padding: 32px 48px;
    max-width: 800px;
    min-width: 0;
  }

  .docs-footer {
    padding: 24px;
    text-align: center;
    border-top: 1px solid var(--border-dim);
    color: var(--dim);
    font-size: 12px;
  }
  .docs-footer a { color: var(--muted); }

  .topnav-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .sidebar-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 4px;
    line-height: 0;
  }
  .sidebar-toggle:hover { color: var(--fg); }

  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 90;
  }

  @media (max-width: 768px) {
    .sidebar-toggle { display: block; }
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 95;
      height: 100vh;
      width: 260px;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      background: var(--bg);
      border-right: 1px solid var(--border-dim);
      padding-top: 16px;
    }
    .sidebar.open { transform: translateX(0); }
    .sidebar-backdrop.open { display: block; }
    .docs-content { padding: 20px 16px; }
  }
</style>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');

  function openSidebar() {
    sidebar?.classList.add('open');
    backdrop?.classList.add('open');
  }
  function closeSidebar() {
    sidebar?.classList.remove('open');
    backdrop?.classList.remove('open');
  }

  toggle?.addEventListener('click', () => {
    sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
  });
  backdrop?.addEventListener('click', closeSidebar);

  // Close on nav link click (mobile)
  sidebar?.querySelectorAll('.sidebar-link').forEach(link => {
    link.addEventListener('click', closeSidebar);
  });
</script>
