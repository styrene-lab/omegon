{
  "auth.login_anthropic": {
    "cmd": "omegon auth login anthropic",
    "desc": "OAuth login for Anthropic/Claude"
  },
  "auth.login_openai_codex": {
    "cmd": "omegon auth login openai-codex",
    "desc": "OAuth login for OpenAI/Codex"
  },
  "auth.login_ollama_cloud": {
    "cmd": "omegon auth login ollama-cloud",
    "desc": "Configure Ollama Cloud API key"
  },
  "auth.auth_status": {
    "cmd": "omegon auth status",
    "desc": "Show authentication status for all providers"
  },
  "auth.set_anthropic_key": {
    "cmd": "omegon secret set ANTHROPIC_API_KEY --stdin",
    "desc": "Store Anthropic API key"
  },
  "auth.set_openai_key": {
    "cmd": "omegon secret set OPENAI_API_KEY --stdin",
    "desc": "Store OpenAI API key"
  },
  "auth.set_ollama_host": {
    "cmd": "export OLLAMA_HOST=\"http://127.0.0.1:11434\"",
    "desc": "Configure local Ollama endpoint"
  },
  "cli.resume": {
    "cmd": "omegon --resume",
    "desc": "Resume most recent session"
  },
  "cli.resume_specific": {
    "cmd": "omegon --resume abc123",
    "desc": "Resume a specific session by ID prefix"
  },
  "cli.fresh": {
    "cmd": "omegon --fresh",
    "desc": "Start a fresh session, ignoring saved history"
  },
  "cli.no_session": {
    "cmd": "omegon --no-session",
    "desc": "Disable session auto-save"
  },
  "cli.headless_prompt": {
    "cmd": "omegon --prompt \"Summarize README.md\"",
    "desc": "Execute single prompt and exit"
  },
  "cli.headless_file": {
    "cmd": "omegon --prompt-file task.md",
    "desc": "Read prompt from file"
  },
  "cli.headless_bounded": {
    "cmd": "omegon --prompt \"Fix the failing test\" --max-turns 10",
    "desc": "Limit agent turns"
  },
  "cli.smoke": {
    "cmd": "omegon --smoke",
    "desc": "Run smoke tests"
  },
  "cli.serve": {
    "cmd": "omegon serve",
    "desc": "Launch persistent daemon/control-plane"
  },
  "cli.migrate_auto": {
    "cmd": "omegon migrate auto",
    "desc": "Auto-detect and import from all sources"
  },
  "cli.migrate_claude": {
    "cmd": "omegon migrate claude-code",
    "desc": "Import from Claude Code"
  },
  "cli.migrate_codex": {
    "cmd": "omegon migrate codex",
    "desc": "Import from OpenAI Codex CLI"
  },
  "cli.migrate_cursor": {
    "cmd": "omegon migrate cursor",
    "desc": "Import from Cursor"
  },
  "cli.extension_install": {
    "cmd": "omegon extension install <git-url-or-local-path>",
    "desc": "Install extension from git URL or local path"
  },
  "cli.extension_install_vox": {
    "cmd": "omegon extension install https://github.com/styrene-lab/vox.git",
    "desc": "Install Vox communication extension"
  },
  "cli.extension_install_scry": {
    "cmd": "omegon extension install https://github.com/styrene-lab/scry.git",
    "desc": "Install Scry image generation extension"
  },
  "cli.extension_list": {
    "cmd": "omegon extension list",
    "desc": "List installed extensions"
  },
  "cli.extension_update": {
    "cmd": "omegon extension update",
    "desc": "Update all extensions"
  },
  "cli.extension_remove": {
    "cmd": "omegon extension remove vox",
    "desc": "Remove an extension"
  },
  "cli.extension_init": {
    "cmd": "omegon extension init my-extension",
    "desc": "Scaffold a new extension project"
  },
  "cli.dev_clone_build": {
    "cmd": "git clone https://github.com/styrene-lab/omegon.git\ncd omegon\ncargo build -p omegon\ncargo test -p omegon",
    "desc": "Clone, build, and test from source"
  },
  "cli.release_workflow": {
    "cmd": "just release\njust sign\njust publish",
    "desc": "Release workflow (tag, build, optionally sign, publish)"
  },
  "install.quick_install": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh",
    "desc": "Quick install — downloads latest signed binary"
  },
  "install.install_custom_dir": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | INSTALL_DIR=~/.local/bin sh",
    "desc": "Install to a custom directory"
  },
  "install.install_nightly": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh -s -- --channel=nightly",
    "desc": "Install latest nightly"
  },
  "install.install_version": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh -s -- --version=v0.27.1",
    "desc": "Install a specific version"
  },
  "install.install_ci": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh -s -- --no-confirm",
    "desc": "Non-interactive install (CI)"
  },
  "install.brew_stable": {
    "cmd": "brew tap styrene-lab/tap\nbrew install omegon",
    "desc": "Homebrew install"
  },
  "install.brew_upgrade_stable": {
    "cmd": "brew upgrade omegon",
    "desc": "Update Homebrew install"
  },
  "install.update_script": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh",
    "desc": "Re-run install script to update"
  },
  "quickstart.setup_codex": {
    "cmd": "curl -fsSL https://omegon.styrene.io/install.sh | sh\nomegon auth login openai-codex\nom",
    "desc": "Install + OpenAI/Codex OAuth + start slim mode"
  },
  "quickstart.setup_apikey": {
    "cmd": "export ANTHROPIC_API_KEY=\"sk-ant-...\"\nom",
    "desc": "Start with Anthropic API key"
  },
  "quickstart.setup_ollama": {
    "cmd": "ollama pull qwen3:32b\nom",
    "desc": "Pull an Ollama model and start"
  },
  "quickstart.start_slim": {
    "cmd": "om",
    "desc": "Start Omegon in slim terminal-first posture"
  },
  "quickstart.start_full": {
    "cmd": "omegon",
    "desc": "Start Omegon in full harness mode"
  },
