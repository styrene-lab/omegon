  "verify.cosign_verify": {
    "cmd": "cosign verify-blob omegon-0.27.1-aarch64-apple-darwin.tar.gz \\\n  --signature omegon-0.27.1-aarch64-apple-darwin.tar.gz.sig \\\n  --certificate omegon-0.27.1-aarch64-apple-darwin.tar.gz.pem \\\n  --certificate-identity-regexp '.*' \\\n  --certificate-oidc-issuer https://token.actions.githubusercontent.com",
    "desc": "Verify cosign signature (keyless) — replace version with actual"
  },
  "verify.gh_attestation": {
    "cmd": "gh attestation verify omegon-*.tar.gz --repo styrene-lab/omegon",
    "desc": "Verify GitHub Attestations (build provenance)"
  }
