---
import Docs from "../layouts/Docs.astro";
import { readFileSync } from "node:fs";
import { join } from "node:path";

// Read root CHANGELOG.md — Astro will process this at build time
const changelogPath = join(process.cwd(), "..", "CHANGELOG.md");
let raw = "";
try {
  raw = readFileSync(changelogPath, "utf-8");
} catch {
  raw = "# Changelog\n\n*Not available during this build.*";
}

// Use Astro's built-in markdown rendering
const { default: markdownit } = await import("markdown-it");
const md = markdownit({ html: true, linkify: true });
const html = md.render(raw);
---

<Docs title="Changelog" description="Release history for omegon.">
  <Fragment set:html={html} />
</Docs>
