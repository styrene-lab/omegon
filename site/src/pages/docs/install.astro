    <thead><tr><th>Platform</th><th>Architecture</th><th>Status</th></tr></thead>
    <tbody>
      <tr><td>macOS</td><td>aarch64 (Apple Silicon)</td><td>✓ Primary</td></tr>
      <tr><td>macOS</td><td>x86_64 (Intel)</td><td>✓ Supported</td></tr>
      <tr><td>Linux</td><td>x86_64</td><td>✓ Supported</td></tr>
      <tr><td>Linux</td><td>aarch64</td><td>✓ Supported (cross-compiled)</td></tr>
      <tr><td>Windows</td><td>—</td><td>Use WSL2</td></tr>
    </tbody>
  </table>
</Docs>
