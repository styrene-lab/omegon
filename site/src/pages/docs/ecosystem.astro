      <tr><td>Claude Code CLAUDE.md</td><td>Yes</td><td>Read directly, no migration needed</td></tr>
      <tr><td>Cursor rules</td><td>Yes</td><td><code>omegon migrate cursor</code></td></tr>
      <tr><td>Windsurf rules</td><td>Yes</td><td><code>omegon migrate windsurf</code></td></tr>
      <tr><td>Codex CLI AGENTS.md</td><td>Yes</td><td>Native format</td></tr>
      <tr><td>Aider config</td><td>Yes</td><td><code>omegon migrate aider</code></td></tr>
      <tr><td>Any MCP server</td><td>Yes</td><td><code>.omegon/mcp.toml</code></td></tr>
      <tr><td>OpenAPI REST API</td><td>Yes</td><td><code>.omegon/openapi.toml</code></td></tr>
      <tr><td>Ollama models</td><td>Yes</td><td>Auto-detected on localhost</td></tr>
      <tr><td>OpenAI API key</td><td>Yes</td><td><code>export OPENAI_API_KEY=...</code></td></tr>
