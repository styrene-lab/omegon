---
import "../styles/global.css";
import { readFileSync } from "fs";
import { resolve } from "path";
import {
  canonicalSiteUrl,
  installScriptUrl,
  isPreviewSite,
  previewSiteUrl,
} from "../lib/siteVariant";

const changelog = readFileSync(resolve("../CHANGELOG.md"), "utf-8");
const versionMatch = changelog.match(/## \[([0-9]+\.[0-9]+\.[0-9]+)\]/);
const currentVersion = versionMatch ? `v${versionMatch[1]}` : "latest";

const valueCards = [
  {
    title: "Direct file and shell control",
    body: "Read and edit files, run shell commands, inspect output, and commit the result from one terminal session without handing work off to another app.",
  },
  {
    title: "Persistent project memory",
    body: "Store durable facts, decisions, and known issues across sessions so the agent can resume work with actual project context instead of starting cold.",
  },
  {
    title: "Scoped parallel work",
    body: "Split larger changes into git worktree children with bounded file scope, dependency ordering, and merge-back into the parent branch.",
  },
  {
    title: "Design and spec discipline",
    body: "Track design exploration in the design tree and tie implementation work to OpenSpec scenarios when the change is large enough to need them.",
  },
  {
    title: "Provider transparency",
    body: "Show the concrete backend in use — Anthropic/Claude, OpenAI API, OpenAI/Codex, or Ollama — along with runtime and quota context when the provider exposes it.",
  },
  {
    title: "Operationally simple",
    body: "One Rust binary, signed releases, no runtime Node.js dependency, and a docs/install surface that stays separate between stable and preview channels.",
  },
];

const modeTitle = isPreviewSite ? "Preview / staging docs" : "Public stable docs";
const modeBody = isPreviewSite
  ? "Release-candidate and nightly guidance lives here. Stable operator guidance stays on the public .io surface."
  : "Stable install, onboarding, and product guidance lives here. Preview and RC guidance stays on the .styrene.dev surface.";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Omegon — Terminal-Native AI Agent Harness</title>
  <meta name="description" content="Single binary. Native Rust. Real memory. Parallel worktrees. An AI agent harness for operators who build." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tomorrow:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
</head>
<body>
  <nav class="topnav">
    <a href="/" class="topnav-logo">Omegon</a>
    <div class="topnav-links">
      <a href="/docs/">Docs</a>
      <a href="/changelog">Changelog</a>
      <a href="https://github.com/styrene-lab/omegon">GitHub</a>
    </div>
  </nav>

  <main class="landing-shell">
    <section class="hero-grid">
      <div class="hero-copy-column">
        <div class="hero-kicker">{modeTitle}</div>
        <h1>A terminal harness for real software work.</h1>
        <p class="hero-lead">
          Omegon gives an agent direct access to files, commands, memory, and lifecycle state without pretending a chat transcript is an engineering process.
        </p>
        <p class="hero-body">
          Use it when the job is bigger than a one-shot prompt: inspect a repository, make a multi-file change, preserve decisions, and keep the execution path visible while the work is happening.
        </p>
        <div class="hero-cta-row">
          <a href="/docs/get-started" class="btn btn-primary">Start with installation</a>
          <a href="/docs/" class="btn btn-secondary">Documentation</a>
        </div>
        <div class="hero-proof-row">
          <span>Read, edit, run, commit</span>
          <span>Memory across sessions</span>
          <span>Worktree-based decomposition</span>
        </div>
      </div>

      <div class="hero-rail">
        <section class="brand-panel">
          <img src="/icon.svg" alt="Omegon" class="brand-mark" />
          <div>
            <div class="brand-overline">Terminal-native software harness</div>
            <div class="brand-copy">{modeBody}</div>
          </div>
        </section>

        <section class="install-panel">
          <div class="panel-label">Install</div>
          <h2>Start with one binary.</h2>
          <p class="panel-copy">
            Omegon installs two entrypoints from the same binary: <code>om</code> for the slim terminal-first posture and <code>omegon</code> for the full harness. Use the stable site for production recommendations and the preview site for RC/nightly evaluation.
          </p>

          <div class="install-command-wrap">
            <pre class="install-command"><code id="hero-install-cmd">curl -fsSL {installScriptUrl} | sh</code></pre>
            <button class="copy-btn" id="copy-btn" aria-label="Copy install command" title="Copy">
              <svg class="copy-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              </svg>
              <svg class="check-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none">
                <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div class="version-row">
            <span>installs <a href={`https://github.com/styrene-lab/omegon/releases/tag/${currentVersion}`}>{currentVersion}</a></span>
            <a href="/docs/install">Install docs</a>
          </div>

          {isPreviewSite ? (
            <div class="channel-list">
              <div class="channel-row"><span>Preview channel</span><code>CHANNEL=rc curl -fsSL {previewSiteUrl}/install.sh | sh</code></div>
              <div class="channel-row"><span>Nightly channel</span><code>CHANNEL=nightly curl -fsSL {previewSiteUrl}/install.sh | sh</code></div>
              <div class="channel-row subdued"><span>Stable</span><a href={canonicalSiteUrl}>{canonicalSiteUrl}</a></div>
            </div>
          ) : (
            <div class="channel-list">
              <div class="channel-row"><span>Stable docs</span><a href={`${canonicalSiteUrl}/docs/install`}>{canonicalSiteUrl}/docs/install</a></div>
              <div class="channel-row subdued"><span>Preview / RC</span><a href={`${previewSiteUrl}/docs/install`}>{previewSiteUrl}/docs/install</a></div>
              <div class="channel-row subdued"><span>Homebrew</span><code>brew tap styrene-lab/tap && brew install omegon</code></div>
            </div>
          )}
        </section>
      </div>
    </section>

    <section class="stats-strip">
      <div class="stat-card"><span class="stat-value">~19 MB</span><span class="stat-label">signed binary</span></div>
      <div class="stat-card"><span class="stat-value">10</span><span class="stat-label">provider paths</span></div>
      <div class="stat-card"><span class="stat-value">53</span><span class="stat-label">structured tools</span></div>
      <div class="stat-card"><span class="stat-value">0</span><span class="stat-label">runtime Node deps</span></div>
    </section>

    <section class="value-section">
      <div class="section-heading">
        <div class="section-kicker">Why teams use it</div>
        <h2>Competent about the work itself, not just the words around it.</h2>
      </div>
      <div class="value-grid">
        {valueCards.map((card) => (
          <article class="value-card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="docs-footer">
    <a href="https://github.com/styrene-lab/omegon">GitHub</a> ·
    <a href="https://github.com/styrene-lab/omegon/releases">Releases</a> ·
    <a href="https://github.com/styrene-lab/omegon/blob/main/LICENSE">BSL 1.1</a> ·
    <a href="/terms">Terms</a> ·
    <a href="/privacy">Privacy</a> ·
    © 2024–2026 Black Meridian, LLC
  </footer>

  <script>
    const btn = document.getElementById('copy-btn');
    const cmd = document.getElementById('hero-install-cmd');
    if (btn && cmd) {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(cmd.textContent.trim()).then(() => {
          btn.classList.add('copied');
          btn.querySelector('.copy-icon').style.display = 'none';
          btn.querySelector('.check-icon').style.display = '';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.querySelector('.copy-icon').style.display = '';
            btn.querySelector('.check-icon').style.display = 'none';
          }, 1800);
        });
      });
    }
  </script>
</body>
</html>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(2, 3, 10, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-dim);
    padding: 16px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .topnav-logo {
    font-size: 18px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.5px;
    text-decoration: none;
  }

  .topnav-links {
    display: flex;
    gap: 24px;
    font-size: 14px;
  }

  .topnav-links a {
    color: var(--muted);
  }

  .topnav-links a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .landing-shell {
    max-width: 1280px;
    margin: 0 auto;
    padding: 40px 28px 96px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.95fr);
    gap: 40px;
    align-items: start;
    padding: 24px 0 36px;
  }

  .hero-copy-column {
    padding-top: 18px;
  }

  .hero-kicker,
  .section-kicker,
  .panel-label,
  .brand-overline {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 12px;
    color: var(--accent);
    font-weight: 700;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 18px 0 20px;
    max-width: 10ch;
  }

  .hero-lead {
    font-size: 1.2rem;
    color: var(--fg);
    max-width: 34rem;
    margin-bottom: 16px;
  }

  .hero-body {
    color: var(--muted);
    max-width: 40rem;
    margin-bottom: 24px;
    font-size: 1rem;
  }

  .hero-cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    border-radius: 2px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--border);
    letter-spacing: 0.02em;
  }

  .btn-primary {
    background: transparent;
    color: var(--accent);
    border-color: var(--accent);
  }

  .btn-primary:hover {
    color: var(--fg);
    text-decoration: none;
    background: rgba(42, 180, 200, 0.08);
  }

  .btn-secondary {
    color: var(--fg);
    background: transparent;
    border-color: var(--border-dim);
  }

  .btn-secondary:hover {
    text-decoration: none;
    border-color: var(--accent-muted);
    background: rgba(26, 68, 88, 0.12);
  }

  .hero-proof-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-proof-row span {
    border: 1px solid var(--border-dim);
    background: transparent;
    color: var(--muted);
    border-radius: 0;
    padding: 8px 12px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-rail {
    display: grid;
    gap: 18px;
  }

  .brand-panel,
  .install-panel,
  .value-card,
  .stat-card {
    background: rgba(6, 10, 20, 0.94);
    border: 1px solid rgba(42, 180, 200, 0.12);
    box-shadow: none;
  }

  .brand-panel {
    border-radius: 0;
    padding: 20px 22px;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 18px;
    align-items: center;
  }

  .brand-mark {
    width: 100%;
    max-width: 110px;
    display: block;
  }

  .brand-copy {
    color: var(--muted);
    margin-top: 8px;
    font-size: 14px;
    line-height: 1.6;
  }

  .install-panel {
    border-radius: 0;
    padding: 24px;
  }

  .install-panel h2 {
    font-size: 1.8rem;
    letter-spacing: -0.03em;
    margin: 10px 0 10px;
  }

  .panel-copy {
    color: var(--muted);
    margin-bottom: 18px;
  }

  .install-command-wrap {
    position: relative;
    margin-bottom: 14px;
  }

  .install-command {
    margin: 0;
    padding: 16px 52px 16px 18px;
    background: rgba(4, 8, 18, 0.92);
    border: 1px solid var(--border);
    border-radius: 0;
    font-size: 14px;
    color: var(--accent);
    overflow-x: auto;
  }

  .install-command code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .copy-btn {
    position: absolute;
    top: 50%;
    right: 12px;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 6px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
  }

  .copy-btn:hover {
    color: var(--fg);
    background: rgba(26, 68, 88, 0.16);
  }

  .copy-btn.copied {
    color: var(--accent);
  }

  .copy-btn svg {
    width: 16px;
    height: 16px;
  }

  .version-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--dim);
    margin-bottom: 16px;
  }

  .version-row a {
    color: var(--accent);
  }

  .channel-list {
    display: grid;
    gap: 10px;
  }

  .channel-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 12px;
    align-items: start;
    font-size: 13px;
    color: var(--fg);
  }

  .channel-row span {
    color: var(--muted);
    font-weight: 700;
  }

  .channel-row code {
    font-size: 12px;
  }

  .channel-row.subdued {
    color: var(--muted);
  }

  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin: 10px 0 56px;
  }

  .stat-card {
    border-radius: 0;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-value {
    color: var(--fg);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .stat-label {
    color: var(--muted);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .value-section {
    padding-top: 8px;
  }

  .section-heading {
    display: grid;
    gap: 10px;
    margin-bottom: 24px;
    max-width: 52rem;
  }

  .section-heading h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .value-card {
    border-radius: 0;
    padding: 22px;
    min-height: 200px;
  }

  .value-card h3 {
    margin: 0 0 12px;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .value-card p {
    margin: 0;
    color: var(--muted);
  }

  .docs-footer {
    padding: 28px;
    text-align: center;
    border-top: 1px solid var(--border-dim);
    color: var(--dim);
    font-size: 12px;
  }

  .docs-footer a {
    color: var(--muted);
  }

  @media (max-width: 1080px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .stats-strip,
    .value-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .topnav {
      padding: 14px 18px;
    }

    .topnav-links {
      gap: 14px;
      font-size: 13px;
    }

    .landing-shell {
      padding: 28px 18px 72px;
    }

    .brand-panel {
      grid-template-columns: 1fr;
    }

    .brand-mark {
      max-width: 90px;
    }

    .stats-strip,
    .value-grid {
      grid-template-columns: 1fr;
    }

    .channel-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
