---
import Docs from "../layouts/Docs.astro";
import { readRepoDoc } from "../lib/repo-docs";

// Throws (failing the build) if PRIVACY.md can't be read.
let raw = readRepoDoc("PRIVACY.md");

const siteLabel = "https://omegon.styrene.io";
raw = raw
  .replace(/omegon\.styrene\.dev website/g, `${siteLabel} website`)
  .replace(/omegon\.styrene\.dev Website/g, `${siteLabel} Website`);

const { default: markdownit } = await import("markdown-it");
const md = markdownit({ html: true, linkify: true });
const html = md.render(raw);
---

<Docs title="Privacy Policy" description={`Privacy policy for the Omegon software and the ${siteLabel} website.`}>
  <Fragment set:html={html} />
</Docs>
